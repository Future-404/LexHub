{
  "name": "lexhub-core",
  "version": "2.0.0",
  "description": "LexHub Core Process Manager & Web API Server",
  "main": "dist/index.js",
  "bin": {
    "lh": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:deps": "madge --circular --extensions ts --ts-config tsconfig.json src/"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/reply-from": "^12.6.2",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "commander": "^12.1.0",
    "fastify": "^5.9.0",
    "undici": "^8.5.0",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "madge": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@fastify/reply-from": {
      "undici": "^6.27.0"
    },
    "fast-uri": "^3.1.2",
    "fast-jwt": "^6.2.4"
  }
}
