{
  "id": "sillytavern",
  "name": "SillyTavern",
  "version": "1.12.0",
  "author": "SillyTavern Team",
  "description": "SillyTavern 是一个可以安装在你电脑上（以及 Android 手机）的用户界面，允许你与文本生成 AI 进行互动，并与你或社区创建的角色进行聊天或角色扮演。",
  "icon": "🎭",
  "categories": ["AI", "Chat", "Roleplay"],
  "platforms": ["linux", "windows", "termux"],
  "repo_url": "https://github.com/SillyTavern/SillyTavern.git",
  "branch": "release",
  "dependencies": {
    "binaries": ["node", "npm", "git"]
  },
  "env": {
    "PORT": { "default": 8000, "description": "监听端口" },
    "LISTEN": { "default": "0.0.0.0", "description": "监听地址 (0.0.0.0=公网, 127.0.0.1=仅本机)" },
    "NODE_MEMORY": { "default": 0, "description": "Node.js 内存限制 MB (0=自动, 建议 4096)" }
  },
  "app_config_schema": {
    "network": {
      "label": "网络与服务 (Server)",
      "icon": "🌐",
      "fields": [
        { "key": "port", "label": "服务端口 (Port)", "type": "int", "default": 8000 },
        { "key": "listen", "label": "允许外部访问 (Listen)", "type": "bool", "default": false },
        { "key": "listenAddress.ipv4", "label": "IPv4 监听地址", "type": "string", "default": "0.0.0.0" },
        { "key": "protocol.ipv4", "label": "启用 IPv4", "type": "bool", "default": true },
        { "key": "protocol.ipv6", "label": "启用 IPv6", "type": "bool", "default": false },
        { "key": "browserLaunch.enabled", "label": "启动时自动打开浏览器", "type": "bool", "default": true },
        { "key": "ssl.enabled", "label": "启用 HTTPS (SSL)", "type": "bool", "default": false }
      ]
    },
    "security": {
      "label": "安全与认证 (Security)",
      "icon": "🛡️",
      "fields": [
        { "key": "whitelistMode", "label": "启用白名单模式", "type": "bool", "default": true },
        { "key": "enableForwardedWhitelist", "label": "白名单校验代理 IP", "type": "bool", "default": true },
        { "key": "basicAuthMode", "label": "基础身份验证 (Basic Auth)", "type": "bool", "default": false },
        { "key": "basicAuthUser.username", "label": "Basic Auth 用户名", "type": "string", "default": "user" },
        { "key": "basicAuthUser.password", "label": "Basic Auth 密码", "type": "string", "default": "password" },
        { "key": "enableUserAccounts", "label": "多用户账号系统", "type": "bool", "default": false },
        { "key": "enableDiscreetLogin", "label": "隐私登录模式", "type": "bool", "default": false },
        { "key": "perUserBasicAuth", "label": "单账号独立密码", "type": "bool", "default": false },
        { "key": "hostWhitelist.enabled", "label": "防 Host 伪造校验", "type": "bool", "default": false },
        { "key": "privateAddressWhitelist.enabled", "label": "防御 SSRF 攻击", "type": "bool", "default": false },
        { "key": "disableCsrfProtection", "label": "禁用 CSRF 保护 (不推荐)", "type": "bool", "default": false }
      ]
    },
    "sso_proxy": {
      "label": "代理与单点登录 (SSO)",
      "icon": "🔑",
      "fields": [
        { "key": "enableCorsProxy", "label": "启用内置 CORS 代理", "type": "bool", "default": false },
        { "key": "cors.enabled", "label": "启用 CORS", "type": "bool", "default": true },
        { "key": "requestProxy.enabled", "label": "通过代理发送传出请求", "type": "bool", "default": false },
        { "key": "requestProxy.url", "label": "传出请求代理 URL", "type": "string", "default": "socks5://username:password@example.com:1080" },
        { "key": "sso.autheliaAuth", "label": "Authelia 自动登录", "type": "bool", "default": false },
        { "key": "sso.authentikAuth", "label": "Authentik 自动登录", "type": "bool", "default": false },
        { "key": "forwardedHeaders.xRealIp", "label": "信任 X-Real-IP", "type": "bool", "default": true },
        { "key": "forwardedHeaders.xForwardedFor", "label": "信任 X-Forwarded-For", "type": "bool", "default": true },
        { "key": "forwardedHeaders.cfConnectingIp", "label": "信任 CF-Connecting-IP", "type": "bool", "default": false }
      ]
    },
    "performance": {
      "label": "性能与扩展 (Performance)",
      "icon": "⚡",
      "fields": [
        { "key": "performance.lazyLoadCharacters", "label": "延迟加载角色卡", "type": "bool", "default": false },
        { "key": "performance.useDiskCache", "label": "启用磁盘缓存", "type": "bool", "default": true },
        { "key": "performance.requestCompression.enabled", "label": "启用请求 Gzip 压缩", "type": "bool", "default": false },
        { "key": "extensions.enabled", "label": "启用 UI 扩展", "type": "bool", "default": true },
        { "key": "extensions.autoUpdate", "label": "自动更新扩展", "type": "bool", "default": true },
        { "key": "extensions.models.autoDownload", "label": "自动下载扩展模型", "type": "bool", "default": true },
        { "key": "enableServerPlugins", "label": "启用服务器插件", "type": "bool", "default": false },
        { "key": "git.backend", "label": "Git 后端模式", "type": "select", "options": ["auto", "system", "builtin"], "default": "auto" }
      ]
    },
    "ai": {
      "label": "AI API 高级参数",
      "icon": "🤖",
      "fields": [
        { "key": "claude.enableSystemPromptCache", "label": "Claude 提示词缓存", "type": "bool", "default": false },
        { "key": "claude.cachingAtDepth", "label": "Claude 缓存深度 (-1=关闭)", "type": "int", "default": -1 },
        { "key": "claude.enableAdaptiveThinking", "label": "Claude 适应性思维", "type": "bool", "default": false },
        { "key": "mistral.enablePrefix", "label": "Mistral 消息预填充", "type": "bool", "default": false },
        { "key": "ollama.keepAlive", "label": "Ollama 模型驻留时间(秒)", "type": "int", "default": -1 },
        { "key": "ollama.batchSize", "label": "Ollama Batch Size (-1=默认)", "type": "int", "default": -1 },
        { "key": "gemini.apiVersion", "label": "Gemini API 版本", "type": "select", "options": ["v1beta", "v1alpha"], "default": "v1beta" },
        { "key": "gemini.thoughtSignatures", "label": "Gemini 思维链", "type": "bool", "default": true }
      ]
    },
    "backup_log": {
      "label": "备份与日志 (Backup & Log)",
      "icon": "💾",
      "fields": [
        { "key": "backups.allowFullDataBackup", "label": "允许用户完整备份", "type": "bool", "default": true },
        { "key": "backups.chat.enabled", "label": "聊天自动备份", "type": "bool", "default": true },
        { "key": "backups.common.numberOfBackups", "label": "每个文件保留备份数", "type": "int", "default": 50 },
        { "key": "logging.enableAccessLog", "label": "记录访问日志", "type": "bool", "default": true },
        { "key": "logging.minLogLevel", "label": "最低日志级别 (0=DEBUG)", "type": "int", "default": 0 }
      ]
    }
  },
  "port_mapping": {
    "source": 8000,
    "target": 8000
  }
}